{
  "entities": {
    "newsItems": {
      "title": "News Item",
      "description": "A single news slide for the broadcast",
      "type": "object",
      "properties": {
        "headline": { "type": "string" },
        "scrollingText": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string", "enum": ["image", "video"] },
        "duration": { "type": "number" },
        "isBreakingNews": { "type": "boolean" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["headline", "scrollingText", "mediaUrl", "mediaType", "duration", "order"]
    },
    "appStatus": {
      "title": "App Status",
      "description": "Real-time state shared across dashboard and live output",
      "type": "object",
      "properties": {
        "activeItemId": { "type": "string" },
        "isPlaying": { "type": "boolean" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "mode": { "type": "string", "enum": ["news", "video"] },
        "activeVideoUrl": { "type": "string" },
        "videoSource": { "type": "string", "enum": ["youtube", "facebook", "direct", "embed", "hls"] },
        "embedCode": { "type": "string" },
        "isPlaylistActive": { "type": "boolean" },
        "currentVideoId": { "type": "string" },
        "volume": { "type": "number" },
        "isPlaying": { "type": "boolean" },
        "isMuted": { "type": "boolean" },
        "loop": { "type": "boolean" },
        "isShuffle": { "type": "boolean" },
        "transportAction": { "type": "string", "enum": ["play", "pause", "stop", "restart", "next", "prev"] },
        "stationName": { "type": "string" },
        "socialHandle": { "type": "string" }
      }
    },
    "tvVideo": {
      "title": "TV Video",
      "description": "A video in the TV playlist",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string", "enum": ["youtube", "facebook", "direct", "embed", "hls"] },
        "embedCode": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "tvAd": {
      "title": "TV Ad",
      "description": "An advertisement image/overlay",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string" },
        "title": { "type": "string" },
        "active": { "type": "boolean" }
      }
    },
    "tvLowerThird": {
      "title": "TV Lower Third",
      "description": "A lower third overlay",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "active": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "/newsItems/{itemId}": {
      "schema": "newsItems",
      "description": "Collection of news items in the queue"
    },
    "/status/current": {
      "schema": "appStatus",
      "description": "Singleton for current playback status"
    },
    "/tvVideos/{videoId}": {
      "schema": "tvVideo",
      "description": "Playlist of videos for the TV mode"
    },
    "/tvAds/{adId}": {
      "schema": "tvAd",
      "description": "Collection of advertisements"
    },
    "/tvLowerThirds/{ltId}": {
      "schema": "tvLowerThird",
      "description": "Collection of lower third templates"
    }
  }
}
